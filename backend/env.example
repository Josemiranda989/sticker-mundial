# ─────────────────────────────────────────────────────────────
# Copiar este archivo a ".env"  ->  cp env.example .env
# ─────────────────────────────────────────────────────────────
# Supabase + Prisma — OJO con esto (es el gotcha clasico)
#
# Supabase te da DOS connection strings. Prisma necesita LAS DOS:
#
# DATABASE_URL  -> Connection Pooling (PgBouncer), puerto 6543.
#                  Se usa en runtime para las queries de la app.
#                  TIENE que llevar ?pgbouncer=true
#
# DIRECT_URL    -> Conexion directa, puerto 5432.
#                  Se usa SOLO para correr migraciones (prisma migrate).
#
# Las sacas de: Supabase Dashboard -> Project Settings -> Database
# ─────────────────────────────────────────────────────────────

DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:5432/postgres"

# Puerto del servidor (Render lo inyecta automaticamente)
PORT=4000

# Origen permitido para CORS (la URL del frontend en Vercel)
# En local: http://localhost:5173
FRONTEND_URL="http://localhost:5173"
